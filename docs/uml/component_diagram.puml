@startuml
' Hybrid Movie Recommendation System — Component Diagram
' Render: https://www.plantuml.com/plantuml/svg/<encoded>

title Hybrid Movie Recommendation System — Component Diagram
left to right direction
skinparam shadowing false
skinparam componentStyle rectangle
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam dpi 160

skinparam ArrowColor #2F4F4F
skinparam PackageBorderColor #2F4F4F
skinparam ComponentBorderColor #2F4F4F
skinparam ArtifactBorderColor #2F4F4F
skinparam DatabaseBorderColor #2F4F4F

legend left
  == Runtime blocks ==
  <<container>> Docker container
  <<service>> Core/business logic
  <<ml>> ML component
  <<db>> Database
  <<monitoring>> Monitoring
  <<cloud>> External API
endlegend

node "User Machine" as user_node {
  component "Streamlit UI\n(frontend/app.py)" as streamlit <<container>>
}

node "Docker Host (docker-compose)" as docker_node {

  package "movie_backend (container)" as backend_pkg {
    component "FastAPI App\n(src/main.py)" as fastapi <<container>>
    component "RecommenderService\n(src/services/recommender.py)" as recommender <<service>>

    package "ML Components" as ml_pkg {
      component "FAISS\nVector Search" as faiss <<ml>>
      component "ALS\nCollaborative Filtering" as als <<ml>>
      component "MiniLM\nEmbeddings" as minilm <<ml>>
    }

    folder "Model Artifacts (volume)" as artifacts {
      artifact "movies_faiss.index" as faiss_index
      artifact "als_model.pkl" as als_pkl
    }
  }

  database "PostgreSQL\nmovie_db (container)" as postgres <<db>>

  package "Monitoring (containers)" as mon_pkg {
    component "Prometheus" as prometheus <<monitoring>>
    component "Grafana" as grafana <<monitoring>>
  }
}

cloud "Groq API\nLLM Llama-3" as groq <<cloud>>

' --- User request path ---
streamlit --> fastapi : HTTP POST /recommend\n(query, user_id, k)
fastapi --> recommender : call get_recommendations()

' --- Data + ML dependencies ---
recommender --> postgres : SQL (metadata, ratings)
recommender --> faiss : top-K by vector similarity
recommender --> als : user-based scoring
recommender --> groq : translate + rerank + explain

faiss --> faiss_index : read index
als --> als_pkl : read model
minilm ..> faiss : same embedding space

' --- Monitoring ---
fastapi --> prometheus : expose /metrics
prometheus --> fastapi : scrape /metrics (pull)
grafana --> prometheus : dashboards/queries

note right of postgres
  Stores:
  - movies metadata
  - user ratings (optional)
end note

note right of artifacts
  Offline-trained artifacts:
  - FAISS index
  - ALS model (.pkl)
end note

@enduml
